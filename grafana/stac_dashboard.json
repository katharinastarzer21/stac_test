{
  "title": "EODC STAC E2E Monitoring",
  "uid": "eodc-stac-e2e",
  "description": "Availability, functional correctness and performance monitoring for the EODC STAC API",
  "tags": ["eodc", "stac", "e2e"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 41,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(eodc_e2e_probe_success, env)",
        "query": {
          "qryType": 1,
          "query": "label_values(eodc_e2e_probe_success, env)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "options": [],
        "current": {}
      },
      {
        "name": "collection",
        "label": "Collection",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(eodc_e2e_probe_success{env=\"$env\"}, collection)",
        "query": {
          "qryType": 1,
          "query": "label_values(eodc_e2e_probe_success{env=\"$env\"}, collection)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "options": [],
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [

    {
      "id": 100,
      "type": "row",
      "title": "Availability",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Overall Success",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green",  "value": 1.0 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg(eodc_e2e_probe_success{env=\"$env\", collection=~\"$collection\"})",
          "legendFormat": "success",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Last Run",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "timestamp(max(eodc_e2e_probe_success{env=\"$env\"})) * 1000",
          "legendFormat": "last run",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "state-timeline",
      "title": "Probe History (green = OK, red = FAIL)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 20, "x": 4, "y": 1 },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "left",
        "rowHeight": 0.85,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 80, "spanNulls": false },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAIL", "color": "red",   "index": 0 },
                "1": { "text": "OK",   "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_probe_success{env=\"$env\", collection=~\"$collection\"}",
          "legendFormat": "{{probe}} · {{collection}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Probe Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 9 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"],
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_probe_duration_seconds{env=\"$env\", collection=~\"$collection\"}",
          "legendFormat": "{{probe}} · {{collection}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 200,
      "type": "row",
      "title": "Functional",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },

    {
      "id": 10,
      "type": "table",
      "title": "Test Results",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 17 },
      "options": {
        "sortBy": [{ "displayName": "test", "desc": false }],
        "footer": { "show": false },
        "frameIndex": 0,
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "color-background", "filterable": false },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAIL", "color": "red",   "index": 0 },
                "1": { "text": "PASS", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" },    "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "job" },     "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "service" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "env" },     "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "merge", "options": {} }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_functional_success{env=\"$env\"}",
          "legendFormat": "{{test}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "type": "barchart",
      "title": "Test Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 10, "y": 17 },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelMaxLength": 30,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "barRadius": 0,
        "fullHighlight": false,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_functional_duration_seconds{env=\"$env\"}",
          "legendFormat": "{{test}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "stat",
      "title": "Last Run",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 17 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_functional_last_run_timestamp{env=\"$env\"} * 1000",
          "legendFormat": "last run",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 13,
      "type": "stat",
      "title": "Pass Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 21 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green",  "value": 1.0 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg(eodc_e2e_functional_success{env=\"$env\"})",
          "legendFormat": "pass rate",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 300,
      "type": "row",
      "title": "Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "p95 Response Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_perf_p95_seconds{env=\"$env\"}",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "Requests per Second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_perf_rps{env=\"$env\"}",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "type": "gauge",
      "title": "Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 33 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_perf_error_rate{env=\"$env\"}",
          "legendFormat": "{{endpoint}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 23,
      "type": "stat",
      "title": "VUs (last run)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 33 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_perf_vus{env=\"$env\"}",
          "legendFormat": "VUs",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 24,
      "type": "stat",
      "title": "Last Run",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 33 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "eodc_e2e_perf_last_run_timestamp{env=\"$env\"} * 1000",
          "legendFormat": "last run",
          "instant": true,
          "refId": "A"
        }
      ]
    }

  ]
}
